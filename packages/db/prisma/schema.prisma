// This is your Prisma schema file
// Learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider          = "postgresql"
  url               = env("DATABASE_URL")
  shadowDatabaseUrl = env("DATABASE_SHADOW_URL")
}

// ─────────────────────────────────────────────────────────────────
// Layer 0–1: Foundation
// ─────────────────────────────────────────────────────────────────

model Business {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  parentId    String?
  whiteLabel  Json?
  healthScore Int      @default(0)
  defaultLocale String   @default("en-US")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  parent      Business?      @relation("AgencyChildren", fields: [parentId], references: [id])
  children    Business[]     @relation("AgencyChildren")
  memberships Membership[]
  brands      Brand[]
  subscriptions Subscription[]
  auditLogs   AuditLog[]
  knowledgeSources KnowledgeSource[]
  contents    Content[]
  campaigns   Campaign[]
  briefs      Brief[]
  assets      Asset[]
  templates   Template[]
  socialAccounts SocialAccount[]
  approvals   Approval[]
  schedules   Schedule[]
  publishJobs PublishJob[]
  notifications Notification[]
  automations Automation[]
  automationRuns AutomationRun[]
  analyticsEvents AnalyticsEvent[]
  performanceMetrics PerformanceMetric[]
  qualityChecks QualityCheck[]
  costEvents  CostEvent[]
  prompts     Prompt[]
  customers   Customer[]
  projects    Project[]
  llmSettings  LlmSettings?

  @@map("businesses")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String?
  mfaEnabled   Boolean  @default(false)
  mfaSecret    String?
  firstName    String?
  lastName     String?
  avatarUrl    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  memberships  Membership[]
  sessions     Session[]
  notifications Notification[]

  @@map("users")
}

model Membership {
  id         String   @id @default(uuid())
  userId     String
  businessId String
  roleId     String
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  role       Role     @relation(fields: [roleId], references: [id])

  @@unique([userId, businessId])
  @@map("memberships")
}

model Role {
  id          String   @id @default(uuid())
  businessId  String?
  name        String
  permissions Json
  isCustom    Boolean  @default(false)
  createdAt   DateTime @default(now())

  memberships Membership[]

  @@map("roles")
}

model Session {
  id           String   @id @default(uuid())
  userId       String
  refreshToken String   @unique
  deviceInfo   Json?
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Subscription {
  id                   String    @id @default(uuid())
  businessId           String
  plan                 String
  status               SubscriptionStatus
  stripeCustomerId     String?
  stripeSubscriptionId String?
  currentPeriodEnd     DateTime?
  seatLimit            Int       @default(3)
  tokenBudget          Int       @default(100000)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  business             Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

model Customer {
  id          String   @id @default(uuid())
  businessId  String
  name        String
  email       String?
  company     String?
  phone       String?
  status      String   @default("active") // active, lead, inactive
  metadata    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  projects    Project[]

  @@map("customers")
}

model Project {
  id          String   @id @default(uuid())
  businessId  String
  customerId  String?
  name        String
  description String?  @db.Text
  status      String   @default("active") // active, completed, archived
  startDate   DateTime?
  endDate     DateTime?
  budget      Int?
  metadata    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customer    Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  @@map("projects")
}

model AuditLog {
  id           String   @id @default(uuid())
  businessId   String
  userId       String?
  action       String
  entityType   String
  entityId     String?
  before       Json?
  after        Json?
  hash         String
  previousHash String?
  createdAt    DateTime @default(now())

  business     Business @relation(fields: [businessId], references: [id])

  @@map("audit_logs")
}

model CostEvent {
  id          String   @id @default(uuid())
  businessId  String
  module      String
  model       String
  inputTokens Int
  outputTokens Int
  costCents   Int
  requestId   String
  createdAt   DateTime @default(now())

  business    Business @relation(fields: [businessId], references: [id])

  @@map("cost_events")
}

// ─────────────────────────────────────────────────────────────────
// Layer 2: Intelligence
// ─────────────────────────────────────────────────────────────────

model Brand {
  id           String   @id @default(uuid())
  businessId   String
  name         String
  slug         String?
  tagline      String?
  description  String?
  industry     String?
  website      String?
  foundedYear  Int?
  headquarters String?
  status       BrandStatus @default(published)
  locales      Json?    // Supported markets, e.g. ["en-US", "fr-FR"]
  defaultLocale String? @default("en-US")
  
  positioning  String?
  audience     String?
  differentiators String?
  tone         Json?
  visualRules  Json?
  governance   Json?
  
  identity     Json?
  marketing    Json?
  designTokens Json?
  strategy     Json?    // { targetLocation, ageGroup, interests, postingFrequency, festivalPosts, offerPosts, preferredTypes, contentLanguage, ctaPreference }
  competitors  Json?    // [{ name, website, strengths, weaknesses }]
  contactInfo  Json?    // { personName, phoneNumber, email, officeAddress }
  socialAccess Json?    // { metaBusinessManagerId, adAccountId, instagramHandle, facebookPage, linkedinPage, youtubeChannel, twitterHandle }
  
  designPreferences Json? // { preferredStyle, referenceLinks, imageStyle, animationRequirement }
  approvalWorkflow  Json? // { reviewerName, finalApproverName, processSteps, approvalTiming, revisionLimit }
  campaignDetails   Json? // { marketingGoal, monthlyBudget, duration, targetLeads, adPlatforms }
  analyticsConfig   Json? // { monthlyReport, kpiExpectations, leadTracking, engagementTracking }
  
  healthScore  Int      @default(0)
  version      Int      @default(1)
  archivedAt   DateTime?
  deletedAt    DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  business         Business          @relation(fields: [businessId], references: [id], onDelete: Cascade)
  knowledgeSources KnowledgeSource[]
  contents         Content[]
  assets           Asset[]

  @@unique([businessId, slug])
  @@map("brands")
}

model KnowledgeSource {
  id               String    @id @default(uuid())
  businessId       String
  brandId          String
  name             String?
  type             String    // PDF, DOCX, URL, API, NOTION, etc.
  sourceUrl        String?
  fileName         String?
  status           KnowledgeSourceStatus @default(pending) // pending, processing, completed, failed, paused
  trustLevel       String    @default("high")    // high, medium, low
  syncFrequency    String    @default("manual")  // manual, daily, weekly
  versionCount     Int       @default(1)
  crawlDepth       Int?      @default(0)
  metadata         Json?     // Type-specific config (Sitemap, RSS, etc.)
  extractionHealth Float     @default(1.0)
  lastIngested     DateTime?
  ownerId          String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  business     Business         @relation(fields: [businessId], references: [id])
  brand        Brand            @relation(fields: [brandId], references: [id], onDelete: Cascade)
  entries      KnowledgeEntry[]
  jobs         KnowledgeJob[]
  audits       KnowledgeAudit[]

  @@map("knowledge_sources")
}

model KnowledgeEntry {
  id             String    @id @default(uuid())
  businessId     String
  sourceId       String
  classification String?   // product, feature, faq, claim, pricing, etc.
  content        String    @db.Text
  confidence     Float     @default(1.0)
  isStale        Boolean   @default(false)
  staleAt        DateTime?
  metadata       Json?     // citations, tags, region restrictions
  locale         String?   @default("en-US")
  governance     Json?     // compliance tags, sensitive flags
  version        Int       @default(1)
  embedding      Json?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  source        KnowledgeSource         @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  reviews       KnowledgeReview[]
  relationshipsFrom KnowledgeRelationship[] @relation("FromEntry")
  relationshipsTo   KnowledgeRelationship[] @relation("ToEntry")

  @@map("knowledge_entries")
}

model KnowledgeRelationship {
  id           String   @id @default(uuid())
  businessId   String
  fromEntryId  String
  toEntryId    String
  relationType String   // relates_to, supports, contradicts, audience_for
  confidence   Float    @default(1.0)
  createdAt    DateTime @default(now())

  fromEntry    KnowledgeEntry @relation("FromEntry", fields: [fromEntryId], references: [id], onDelete: Cascade)
  toEntry      KnowledgeEntry @relation("ToEntry", fields: [toEntryId], references: [id], onDelete: Cascade)

  @@map("knowledge_relationships")
}

model KnowledgeReview {
  id           String    @id @default(uuid())
  businessId   String
  entryId      String
  reviewerId   String?
  status       String    @default("pending") // pending, validated, rejected, conflict
  note         String?
  aiReasoning  String?
  decidedAt    DateTime?
  createdAt    DateTime  @default(now())

  entry        KnowledgeEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)

  @@map("knowledge_reviews")
}

model KnowledgeJob {
  id           String    @id @default(uuid())
  businessId   String
  sourceId     String
  status       KnowledgeJobStatus @default(pending) // pending, processing, completed, failed
  stage        String    @default("intake")  // intake, extraction, cleaning, classification, indexing
  progress     Int       @default(0)
  error        String?
  logs         Json?
  startedAt    DateTime?
  completedAt  DateTime?
  createdAt    DateTime  @default(now())

  source       KnowledgeSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@map("knowledge_jobs")
}

model KnowledgeAudit {
  id           String   @id @default(uuid())
  businessId   String
  sourceId     String
  action       String   // created, updated, deleted, sync_failed, review_completed
  userId       String?
  changes      Json?
  createdAt    DateTime @default(now())

  source       KnowledgeSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@map("knowledge_audits")
}

model Prompt {
  id               String   @id @default(uuid())
  businessId       String?
  module           String
  layer            String
  name             String
  template         String   @db.Text
  version          Int      @default(1)
  isActive         Boolean  @default(true)
  abVariant        String?
  performanceScore Float?
  config           Json?    // Model overrides, temperature, etc.
  tags             Json?    // e.g. ["social", "ad", "internal"]
  metadata         Json?    // e.g. { "author": "..." }
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  business         Business? @relation(fields: [businessId], references: [id])

  @@map("prompts")
}

model QualityCheck {
  id              String   @id @default(uuid())
  businessId      String
  contentId       String
  passed          Boolean
  confidenceScore Float
  violations      Json?
  category        String?  // brand_voice, factual, regulatory
  remediation     String?  @db.Text
  checkedAt       DateTime @default(now())

  business        Business @relation(fields: [businessId], references: [id])
  content         Content  @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@map("quality_checks")
}

// ─────────────────────────────────────────────────────────────────
// Layer 3–4: Planning & Creation
// ─────────────────────────────────────────────────────────────────

model Campaign {
  id           String   @id @default(uuid())
  businessId   String
  name         String
  description  String?  @db.Text
  status       CampaignStatus @default(draft)
  healthScore  Int      @default(0)
  startDate    DateTime?
  endDate      DateTime?
  clonedFromId String?
  metadata     Json?
  archivedAt   DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  business     Business   @relation(fields: [businessId], references: [id], onDelete: Cascade)
  briefs       Brief[]
  contents     Content[]
  schedules    Schedule[]
  assets       Asset[]
  templates    Template[]
  automations  Automation[]

  @@map("campaigns")
}

model Brief {
  id           String   @id @default(uuid())
  businessId   String
  campaignId   String?
  objective    String
  audience     String?
  platform     String?
  cta          String?
  tone         String?
  format       String?
  contentType  String?
  businessGoal String?
  campaignTheme String?
  isComplete   Boolean  @default(false)
  metadata     Json?
  createdAt    DateTime @default(now())

  business     Business  @relation(fields: [businessId], references: [id])
  campaign     Campaign? @relation(fields: [campaignId], references: [id])
  contents     Content[]

  @@map("briefs")
}

model Content {
  id             String   @id @default(uuid())
  businessId     String
  brandId        String
  briefId        String?
  campaignId     String?
  platform       String
  type           String
  locale         String   @default("en-US")
  body           String   @db.Text
  status         ContentStatus @default(draft)
  qualityScore   Float?
  promptId       String?
  promptVersion  Int?
  metadata       Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  business       Business         @relation(fields: [businessId], references: [id])
  brand          Brand            @relation(fields: [brandId], references: [id])
  brief          Brief?           @relation(fields: [briefId], references: [id])
  campaign       Campaign?        @relation(fields: [campaignId], references: [id])
  versions       ContentVersion[]
  approvals      Approval[]
  qualityChecks  QualityCheck[]
  publishJobs    PublishJob[]
  schedules      Schedule[]

  @@map("contents")
}

model ContentVersion {
  id        String   @id @default(uuid())
  contentId String
  version   Int
  body      String   @db.Text
  editedBy  String?
  createdAt DateTime @default(now())

  content   Content  @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@map("content_versions")
}

model Asset {
  id         String   @id @default(uuid())
  businessId String
  campaignId String?
  type       String
  fileName   String
  mimeType   String
  s3Key      String
  cdnUrl     String?
  tags       Json?
  metadata   Json?
  version    Int      @default(1)
  brandId    String?
  createdAt  DateTime @default(now())

  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  campaign   Campaign? @relation(fields: [campaignId], references: [id])
  brand      Brand?   @relation(fields: [brandId], references: [id], onDelete: SetNull)

  @@map("assets")
}

model Template {
  id               String   @id @default(uuid())
  businessId       String?
  campaignId       String?
  type             String
  name             String
  body             String   @db.Text
  placeholders     Json?
  performanceScore Float?
  usageCount       Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  business         Business? @relation(fields: [businessId], references: [id])
  campaign         Campaign? @relation(fields: [campaignId], references: [id])

  @@map("templates")
}

// ─────────────────────────────────────────────────────────────────
// Layer 5–7: Operations
// ─────────────────────────────────────────────────────────────────

model SocialAccount {
  id             String    @id @default(uuid())
  businessId     String
  platform       String
  accountType    String
  externalId     String
  name           String
  accessToken    String
  refreshToken   String?
  tokenExpiresAt DateTime?
  scopes         Json?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  business       Business    @relation(fields: [businessId], references: [id], onDelete: Cascade)
  publishJobs    PublishJob[]
  schedules      Schedule[]

  @@unique([businessId, platform, externalId])
  @@map("social_accounts")
}

model Approval {
  id          String    @id @default(uuid())
  businessId  String
  contentId   String
  reviewerId  String?
  reviewType  String
  status      ApprovalStatus @default(pending)
  slaDeadline DateTime?
  note        String?
  reason      String?
  decidedAt   DateTime?
  createdAt   DateTime  @default(now())

  business    Business @relation(fields: [businessId], references: [id])
  content     Content  @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@map("approvals")
}

model Schedule {
  id              String    @id @default(uuid())
  businessId      String
  contentId       String?
  campaignId      String?
  socialAccountId String
  scheduledAt     DateTime
  timezone        String    @default("UTC")
  type            String    @default("one_time")
  recurringRule   String?
  status          ScheduleStatus @default(pending)
  createdAt       DateTime  @default(now())

  business        Business      @relation(fields: [businessId], references: [id])
  campaign        Campaign?     @relation(fields: [campaignId], references: [id])
  content         Content?      @relation(fields: [contentId], references: [id])
  socialAccount   SocialAccount @relation(fields: [socialAccountId], references: [id])
  publishJobs     PublishJob[]

  @@map("schedules")
}

model PublishJob {
  id              String    @id @default(uuid())
  businessId      String
  contentId       String
  socialAccountId String
  scheduleId      String?
  tailoredBody    String?   @db.Text
  status          PublishJobStatus @default(pending)
  failureReason   String?
  failureClass    String?
  retryCount      Int       @default(0)
  maxRetries      Int       @default(3)
  nextRetryAt     DateTime?
  publishedAt     DateTime?
  externalPostId  String?
  metadata        Json?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  business        Business      @relation(fields: [businessId], references: [id])
  content         Content       @relation(fields: [contentId], references: [id])
  socialAccount   SocialAccount @relation(fields: [socialAccountId], references: [id])
  schedule        Schedule?     @relation(fields: [scheduleId], references: [id])

  @@map("publish_jobs")
}

model Notification {
  id          String    @id @default(uuid())
  businessId  String
  userId      String
  type        String
  channel     String
  title       String
  body        String?
  isRead      Boolean   @default(false)
  deliveredAt DateTime?
  createdAt   DateTime  @default(now())

  business    Business @relation(fields: [businessId], references: [id])
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

// ─────────────────────────────────────────────────────────────────
// Layer 8–9: Automation & Analytics
// ─────────────────────────────────────────────────────────────────

model Automation {
  id            String    @id @default(uuid())
  businessId    String
  campaignId    String?
  name          String
  triggerType   String
  triggerConfig Json
  steps         Json
  status        AutomationStatus @default(inactive)
  isActive      Boolean   @default(false)
  isDryRun      Boolean   @default(false)
  errorPolicy   Json?
  lastRunAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  business      Business        @relation(fields: [businessId], references: [id], onDelete: Cascade)
  campaign      Campaign?       @relation(fields: [campaignId], references: [id])
  runs          AutomationRun[]

  @@map("automations")
}

model AutomationRun {
  id           String    @id @default(uuid())
  automationId String
  businessId   String
  status       AutomationRunStatus
  triggerEvent Json?
  stepResults  Json?
  failedAtStep Int?
  isDryRun     Boolean   @default(false)
  startedAt    DateTime  @default(now())
  completedAt  DateTime?

  automation   Automation @relation(fields: [automationId], references: [id], onDelete: Cascade)
  business     Business   @relation(fields: [businessId], references: [id])

  @@map("automation_runs")
}

model AnalyticsEvent {
  id         String   @id @default(uuid())
  businessId String
  source     String
  eventType  String
  entityType String?
  entityId   String?
  payload    Json
  createdAt  DateTime @default(now())

  business   Business @relation(fields: [businessId], references: [id])

  @@map("analytics_events")
}

model PerformanceMetric {
  id          String   @id @default(uuid())
  businessId  String
  contentId   String
  platform    String
  reach       Int      @default(0)
  impressions Int      @default(0)
  engagement  Int      @default(0)
  clicks      Int      @default(0)
  ctr         Float    @default(0)
  roiCents    Int      @default(0)
  sourceAttribution Json? // Map of knowledge source IDs and their contribution weights
  collectedAt DateTime @default(now())

  business    Business @relation(fields: [businessId], references: [id])

  @@map("performance_metrics")
}

model LlmSettings {
  id               String   @id @default(uuid())
  businessId       String   @unique
  provider         String   @default("openai") // openai, anthropic, etc.
  model            String   @default("gpt-4o")
  temperature      Float    @default(0.7)
  maxTokens        Int      @default(2000)
  apiKey           String?  @db.Text // Encrypted at rest
  isFallbackEnabled Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  business         Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@map("llm_settings")
}

// ─────────────────────────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────────────────────────

enum SubscriptionStatus {
  trialing
  active
  past_due
  canceled
  unpaid
}

enum BrandStatus {
  draft
  published
  archived
}

enum KnowledgeSourceStatus {
  pending
  processing
  completed
  failed
  paused
}

enum KnowledgeJobStatus {
  pending
  processing
  completed
  failed
}

enum CampaignStatus {
  draft
  active
  paused
  completed
  archived
}

enum ContentStatus {
  draft
  in_review
  revision_requested
  approved
  scheduled
  published
  failed
  archived
}

enum ApprovalStatus {
  pending
  approved
  rejected
  revision_requested
}

enum ScheduleStatus {
  pending
  processing
  published
  failed
  canceled
}

enum PublishJobStatus {
  pending
  processing
  published
  failed
  retrying
  dead_letter
  canceled
}

enum AutomationStatus {
  active
  inactive
  draft
}
enum AutomationRunStatus {
  running
  completed
  failed
  paused
}
