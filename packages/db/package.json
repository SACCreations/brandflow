{
  "name": "@brandflow/db",
  "version": "0.0.1",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js"
  },
  "scripts": {
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
