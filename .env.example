# ==========================================
# BrandFlow — Environment Configuration
# Copy this file to .env and fill in values
# ==========================================

# ─── App ───────────────────────────────────
NODE_ENV=development
APP_PORT=4000
APP_URL=http://localhost:4000
WEB_URL=http://localhost:3002
CORS_ORIGINS=http://localhost:3002

# ─── Database ──────────────────────────────
DATABASE_URL=postgresql://brandflow:brandflow@localhost:5432/brandflow
DATABASE_SHADOW_URL=postgresql://brandflow:brandflow@localhost:5432/brandflow_shadow

# ─── Redis ─────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT ───────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-secret-at-least-64-chars
JWT_REFRESH_SECRET=change-me-to-another-long-random-secret-at-least-64-chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ─── OAuth ─────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/auth/google/callback

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:4000/auth/github/callback

# ─── Social Platforms ──────────────────────
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_CALLBACK_URL=http://localhost:4000/social/linkedin/callback

INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
INSTAGRAM_CALLBACK_URL=http://localhost:4000/social/instagram/callback

FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_CALLBACK_URL=http://localhost:4000/social/facebook/callback

# ─── AI Providers ──────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
AI_DEFAULT_PROVIDER=openai
AI_FALLBACK_PROVIDER=anthropic
AI_REQUEST_TIMEOUT_MS=30000

# ─── Storage (S3 / MinIO) ──────────────────
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=brandflow
S3_REGION=us-east-1
CDN_BASE_URL=http://localhost:9000/brandflow

# ─── Stripe ────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_STARTER_PRICE_ID=
STRIPE_GROWTH_PRICE_ID=
STRIPE_AGENCY_PRICE_ID=
STRIPE_ENTERPRISE_PRICE_ID=

# ─── Encryption ────────────────────────────
# 32-byte hex key for encrypting OAuth tokens at rest
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# ─── Sentry ────────────────────────────────
SENTRY_DSN=

# ─── OpenTelemetry ─────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=brandflow-api

# ─── Rate Limiting ─────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ─── MFA ───────────────────────────────────
MFA_ISSUER=BrandFlow
